# Template público de variáveis de ambiente. Copie para .env e ajuste.
# O .env real NUNCA é commitado (ver .gitignore).

# Senha do Postgres (usada pelo docker-compose)
POSTGRES_PASSWORD=copilot

# URLs consumidas pela API (o compose já injeta valores equivalentes)
DATABASE_URL=postgresql+psycopg2://copilot:copilot@localhost:5432/copilot
REDIS_URL=redis://localhost:6379/0
